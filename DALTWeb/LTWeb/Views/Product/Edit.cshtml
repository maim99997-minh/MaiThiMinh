@model LTWeb.Models.SeafoodItem

<div class="container py-5">
    <div class="card shadow border-0 overflow-hidden">
        <div class="card-header text-white text-center py-3" style="background-color: #002d51;">
            <h4 class="mb-0 text-uppercase fw-bold">Chỉnh sửa thông tin món ăn</h4>
        </div>
        <div class="card-body p-4 bg-light">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Id" class="form-label fw-bold">Mã định danh (ID)</label>
                            <input asp-for="Id" class="form-control bg-white" readonly />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">Tên món hải sản</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Price" class="form-label fw-bold">Giá bán (VNĐ)</label>
                            <input asp-for="Price" class="form-control" type="number" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Category" class="form-label fw-bold">Danh mục sản phẩm</label>
                            <select asp-for="Category" class="form-select">
                                <option value="CÁ">CÁ</option>
                                <option value="CUA - GHẸ">CUA - GHẸ</option>
                                <option value="NGHÊU - SÒ - ỐC">NGHÊU - SÒ - ỐC</option>
                                <option value="BÀO NGƯ - HÀU">BÀO NGƯ - HÀU</option>
                                <option value="TÔM">TÔM</option>
                                <option value="CÁC LOẠI HẢI SẢN KHÁC">CÁC LOẠI HẢI SẢN KHÁC</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="mb-3">
                            @* SỬA: asp-for="ImageUrl" thành asp-for="Image" *@
                            <label asp-for="Image" class="form-label fw-bold">Đường dẫn hình ảnh (URL)</label>
                            <input asp-for="Image" class="form-control" />
                            <span asp-validation-for="Image" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Origin" class="form-label fw-bold">Xuất xứ</label>
                            <input asp-for="Origin" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Weight" class="form-label fw-bold">Trọng lượng / Quy cách</label>
                            <input asp-for="Weight" class="form-control" />
                        </div>
                        @* Thêm phần xem trước ảnh để dễ quản lý *@
                        <div class="mb-3 text-center">
                            <p class="fw-bold mb-1">Xem trước ảnh:</p>
                            <img src="@Model.Image" id="previewImg" style="max-height: 120px; border-radius: 8px; border: 1px solid #ddd;"
                                 onerror="this.src='https://placehold.co/200x150?text=No+Image'" />
                        </div>
                    </div>

                    <div class="col-12 mt-2">
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">Mô tả chi tiết sản phẩm</label>
                            <textarea asp-for="Description" class="form-control" rows="6"></textarea>
                        </div>
                    </div>
                </div>

                <div class="mt-4 d-flex justify-content-center gap-3 border-top pt-4">
                    <a asp-controller="Menu" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary px-4">
                        <i class="fas fa-arrow-left me-2"></i>Hủy và Quay lại
                    </a>
                    <button type="submit" class="btn btn-success px-5 fw-bold text-uppercase">
                        <i class="fas fa-save me-2"></i>Cập nhật
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Tự động cập nhật ảnh xem trước khi thay đổi URL
        $('input[name="Image"]').on('input', function() {
            $('#previewImg').attr('src', $(this).val());
        });
    </script>
}