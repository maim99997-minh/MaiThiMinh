@model IEnumerable<LTWeb.Models.SeafoodItem>
@{
    ViewData["Title"] = "Trang chủ";
}

<div class="position-relative overflow-hidden p-3 p-md-5 text-center bg-light"
     style="background-image: url('https://cdn.tgdd.vn/2021/04/CookProduct/13-1200x676.jpg');
            background-size: cover; background-position: center; height: 500px;">

    <div class="col-md-6 p-lg-5 mx-auto my-5" style="background: rgba(0,0,0,0.5); border-radius: 15px;">
        <h1 class="display-4 fw-normal text-white">Thưởng Thức Vị Biển</h1>
        <p class="lead fw-normal text-white-50">Hải sản tươi sống loại 1 - Chế biến bởi các đầu bếp hàng đầu.</p>
        <a class="btn btn-outline-light btn-lg" asp-controller="Menu" asp-action="Index">Xem thực đơn ngay</a>
    </div>
</div>

<div class="container mt-5 mb-5">
    <div class="row text-center">
        <div class="col-md-4">
            <i class="fas fa-fish fa-3x text-primary mb-3"></i>
            <h3>Tươi Sống</h3>
            <p>Đánh bắt và vận chuyển trực tiếp từ các vùng biển lớn hàng ngày.</p>
        </div>
        <div class="col-md-4">
            <i class="fas fa-utensils fa-3x text-primary mb-3"></i>
            <h3>Chế Biến Tại Chỗ</h3>
            <p>Khách hàng có thể chọn hải sản tại hồ và yêu cầu đầu bếp chế biến.</p>
        </div>
        <div class="col-md-4">
            <i class="fas fa-truck fa-3x text-primary mb-3"></i>
            <h3>Giao Hàng Nhanh</h3>
            <p>Giao hàng tận nơi trong 2 giờ, cam kết chất lượng tươi ngon.</p>
        </div>
    </div>
</div>
<div class="container py-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-uppercase" style="color: #002244;">Sản Phẩm Nổi Bật</h2>
        <div class="mx-auto" style="width: 80px; height: 3px; background-color: #ffc107;"></div>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            @* Sử dụng .Take(4) để chỉ lấy ra 4 sản phẩm đầu tiên trong danh sách *@
            foreach (var item in Model.Take(4))
            {
                <div class="col-md-3">
                    <div class="card h-100 shadow-sm border-0 product-card">
                        <div class="position-relative overflow-hidden">
                            <img src="@item.Image" class="card-img-top" alt="@item.Name" style="height: 200px; object-fit: cover;">
                            <div class="badge bg-danger position-absolute top-0 end-0 m-2">HOT</div>
                        </div>
                        <div class="card-body text-center">
                            <h5 class="card-title fw-bold text-truncate">@item.Name</h5>
                            <p class="text-danger fw-bold mb-2">@item.Price.ToString("N0") VNĐ</p>
                            <a asp-controller="Menu" asp-action="Details" asp-route-id="@item.Id"
                               class="btn btn-sm text-white w-100" style="background-color: #002244; border-radius: 0;">
                                XEM CHI TIẾT
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <p class="text-center text-muted">Đang cập nhật sản phẩm nổi bật...</p>
            </div>
        }
    </div>

<style>
    .product-card {
        transition: transform 0.3s ease;
    }

        .product-card:hover {
            transform: translateY(-10px);
        }

        .product-card img {
            transition: transform 0.5s ease;
        }

        .product-card:hover img {
            transform: scale(1.1);
        }
</style>