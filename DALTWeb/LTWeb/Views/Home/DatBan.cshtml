@model LTWeb.Models.Booking

@{
    ViewData["Title"] = "Đặt Bàn & Quản Lý";
}

<div class="menu-header-banner">
    <div class="container d-flex justify-content-between align-items-center">
        <h1 class="h3 mb-0 text-white text-uppercase">Đặt Bàn</h1>
        <nav class="breadcrumb-custom">
            <a asp-action="Index">Trang chủ</a> / <span class="text-white">Đặt Bàn</span>
        </nav>
    </div>
</div>

<div class="container py-5">
    @* Thông báo thành công *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert" style="border-radius: 0;">
            <strong>Thành công!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-5">
        @* --- CỘT THÔNG TIN LIÊN HỆ --- *@
        <div class="col-md-5">
            <h2 class="h4 fw-bold mb-3">Thông Tin Liên Hệ</h2>
            <p class="mb-4">🐙 <strong>Seafood – MANG CẢ BIỂN KHƠI VỀ NƠI THÀNH PHỐ</strong> 🌊</p>

            <h5 class="fw-bold mb-3 text-uppercase" style="color: #002244;">Hệ Thống Nhà Hàng</h5>
            <ul class="list-unstyled lh-lg">
                <li><i class="fas fa-map-marker-alt me-2 text-danger"></i> <strong>Trung Tâm:</strong> 2-4-6 Hai Bà Trưng, Q.1</li>
                <li><i class="fas fa-map-marker-alt me-2 text-danger"></i> <strong>Cơ sở 1:</strong> 20 Hoàng Việt, Tân Bình</li>
                <li><i class="fas fa-map-marker-alt me-2 text-danger"></i> <strong>Cơ sở 2:</strong> 195 Nam Kỳ Khởi Nghĩa, Q.3</li>
                <li><i class="fas fa-map-marker-alt me-2 text-danger"></i> <strong>Cơ sở 3:</strong> 163A Trần Não, Thủ Đức</li>
                <li class="mt-2"><i class="fas fa-phone-alt me-2 text-primary"></i> <strong>Hotline:</strong> 0378.095.096</li>
            </ul>

            <div class="mt-4">
                <a href="#" class="btn btn-outline-primary btn-sm rounded-circle me-2"><i class="fab fa-facebook-f"></i></a>
                <a href="#" class="btn btn-outline-dark btn-sm rounded-circle"><i class="fab fa-tiktok"></i></a>
            </div>
        </div>

        @* --- CỘT FORM ĐẶT BÀN --- *@
        <div class="col-md-7">
            <div class="card p-4 shadow-sm border-0 bg-light" style="border-radius: 0;">
                <form asp-controller="Home" asp-action="DatBan" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <input asp-for="CustomerName" class="form-control" placeholder="Họ và Tên" style="border-radius: 0;">
                        <span asp-validation-for="CustomerName" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <input asp-for="Email" type="email" class="form-control" placeholder="Email" style="border-radius: 0;">
                        </div>
                        <div class="col-md-6">
                            <input asp-for="Phone" class="form-control" placeholder="Số điện thoại" style="border-radius: 0;">
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <select asp-for="Branch" class="form-select" style="border-radius: 0;">
                                <option value="" selected disabled>Chọn chi nhánh</option>
                                <option value="Quận 1">Trung Tâm - Quận 1</option>
                                <option value="Tân Bình">Cơ sở 1 - Tân Bình</option>
                                <option value="Quận 3">Cơ sở 2 - Quận 3</option>
                                <option value="Thủ Đức">Cơ sở 3 - Thủ Đức</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <input asp-for="BookingDate" type="datetime-local" class="form-control" style="border-radius: 0;">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="small fw-bold mb-1">Số người dự kiến:</label>
                        <input asp-for="NumberOfPeople" type="number" class="form-control" min="1" max="100" style="border-radius: 0;">
                    </div>

                    <div class="mb-4">
                        <textarea asp-for="Note" class="form-control" rows="3" placeholder="Yêu cầu đặc biệt (vị trí bàn, trang trí...)" style="border-radius: 0;"></textarea>
                    </div>

                    <button type="submit" class="btn text-white w-100 fw-bold py-2" style="background-color: #002244; border-radius: 0;">GỬI YÊU CẦU ĐẶT BÀN</button>
                </form>
            </div>
        </div>
    </div>

    @* --- PHẦN 2: DANH SÁCH DÀNH CHO ADMIN (Chỉ Admin mới thấy) --- *@
    @if (User.IsInRole("Admin"))
    {
        <div class="mt-5 pt-5 border-top">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="h4 fw-bold text-danger mb-0"><i class="fas fa-user-shield me-2"></i> QUẢN LÝ ĐẶT BÀN</h3>

                @* Bộ lọc Admin *@
                <div class="d-flex gap-2">
                    <input type="text" id="adminSearch" class="form-control form-control-sm" placeholder="Tìm tên khách/SĐT..." style="width: 250px;">
                    <select id="adminSort" class="form-select form-select-sm" style="width: auto;">
                        <option value="desc">Mới nhất trước</option>
                        <option value="asc">Cũ nhất trước</option>
                    </select>
                </div>
            </div>

            <div class="table-responsive shadow-sm">
                <table class="table table-bordered table-hover align-middle bg-white">
                    <thead class="text-white text-center" style="background-color: #002244;">
                        <tr>
                            <th>Ngày gửi</th>
                            <th>Khách hàng</th>
                            <th>Liên hệ</th>
                            <th>Chi nhánh</th>
                            <th>Ngày đi</th>
                            <th>Số người</th>
                            <th>Ghi chú</th>
                        </tr>
                    </thead>
                    <tbody id="adminTableBody">
                        @if (ViewBag.AdminBookingList != null)
                        {
                            foreach (var item in (IEnumerable<LTWeb.Models.Booking>)ViewBag.AdminBookingList)
                            {
                                <tr class="booking-item" data-timestamp="@item.CreatedAt.Ticks">
                                    <td class="text-center small">@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="fw-bold">@item.CustomerName</td>
                                    <td>
                                        <div>@item.Phone</div>
                                        <div class="small text-muted">@item.Email</div>
                                    </td>
                                    <td class="text-center"><span class="badge bg-info text-dark">@item.Branch</span></td>
                                    <td class="text-center">@item.BookingDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-center fw-bold text-primary">@item.NumberOfPeople</td>
                                    <td class="small">@item.Note</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @* SCRIPT XỬ LÝ LỌC NHANH *@
        <script>
            // 1. Tìm kiếm theo tên hoặc SĐT
            document.getElementById('adminSearch').addEventListener('keyup', function() {
                let val = this.value.toLowerCase();
                let rows = document.querySelectorAll('.booking-item');
                rows.forEach(row => {
                    let text = row.innerText.toLowerCase();
                    row.style.display = text.includes(val) ? '' : 'none';
                });
            });

            // 2. Sắp xếp Theo thời gian
            document.getElementById('adminSort').addEventListener('change', function() {
                let tbody = document.getElementById('adminTableBody');
                let rows = Array.from(tbody.querySelectorAll('.booking-item'));
                let isDesc = this.value === 'desc';

                rows.sort((a, b) => {
                    let timeA = parseInt(a.getAttribute('data-timestamp'));
                    let timeB = parseInt(b.getAttribute('data-timestamp'));
                    return isDesc ? timeB - timeA : timeA - timeB;
                });

                rows.forEach(r => tbody.appendChild(r));
            });
        </script>
    }
</div>