@model LTWeb.Models.SearchViewModel

<div class="container mt-5 pt-5">
    <h3 class="text-white">Kết quả tìm kiếm cho: "@Model.Keyword"</h3>
    <hr class="text-white" />

    @if (Model.Results != null && Model.Results.Any())
    {
        <div class="row">
            @foreach (var item in Model.Results)
            {
                <div class="col-md-3 mb-4">
                    <div class="card h-100 shadow-sm border-0 bg-dark text-white product-item">
                        <div class="position-relative overflow-hidden product-img-box">
                            <img src="@item.Image" class="card-img-top" alt="@item.Name" style="height: 200px; object-fit: cover;">

                            <div class="product-overlay d-flex justify-content-center align-items-center">
                                <button class="btn btn-danger btn-sm rounded-pill px-3"
                                        onclick="cartAction('add', '@item.Id', '@item.Name', '@item.Image', @item.Price, 1)">
                                    <i class="fas fa-shopping-cart"></i> Thêm vào giỏ
                                </button>
                            </div>
                        </div>

                        <div class="card-body text-center">
                            <h5 class="card-title text-warning">@item.Name</h5>
                            <p class="card-text text-danger fw-bold">@item.Price.ToString("N0") VNĐ</p>
                            <div class="d-grid gap-2">
                                <a asp-controller="Menu" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-light btn-sm">
                                    Xem chi tiết
                                </a>
                                <button class="btn btn-primary btn-sm"
                                        onclick="cartAction('buy', '@item.Id', '@item.Name', '@item.Image', @item.Price, 1)">
                                    Mua ngay
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-warning text-center mt-4">
            Không tìm thấy món ăn nào khớp với từ khóa của bạn.
        </div>
    }
</div>