@model List<LTWeb.Models.CartItem>

@{
    ViewData["Title"] = "Giỏ hàng";
}

<div class="container py-5" style="min-height: 60vh;">
    <h2 class="fw-bold mb-4 text-uppercase"><i class="fas fa-shopping-cart me-2"></i>Giỏ hàng của bạn</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5 shadow-sm rounded bg-light border">
            <i class="fas fa-box-open fa-4x text-muted mb-3"></i>
            <p class="fs-5 text-secondary">Giỏ hàng của bạn hiện đang trống.</p>
            <a href="@Url.Action("Index", "Menu")" class="btn btn-primary px-4 py-2 fw-bold">
                <i class="fas fa-arrow-left me-2"></i>TIẾP TỤC CHỌN MÓN
            </a>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-lg-8">
                <div class="table-responsive shadow-sm rounded border bg-white">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th class="ps-3">Sản phẩm</th>
                                <th>Giá</th>
                                <th class="text-center" style="width: 120px;">Số lượng</th>
                                <th>Thành tiền</th>
                                <th class="text-center">Xóa</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-3">
                                        <div class="d-flex align-items-center">
                                            <img src="@item.Image" class="rounded border" width="60" height="60" style="object-fit: cover;" alt="@item.ProductName" />
                                            <div class="ms-3">
                                                <p class="mb-0 fw-bold text-dark">@item.ProductName</p>
                                                <small class="text-muted">Mã: @item.ProductId</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-primary fw-bold">@item.Price.ToString("N0") VNĐ</td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="fw-bold text-danger">@item.Total.ToString("N0") VNĐ</td>
                                    <td class="text-center">
                                        @* Nút xóa món ăn (cần bổ sung Action Remove trong CartController) *@
                                        <a href="@Url.Action("Remove", "Cart", new { id = item.ProductId })"
                                           class="btn btn-outline-danger btn-sm border-0"
                                           onclick="return confirm('Bạn muốn bỏ món này khỏi giỏ hàng?')">
                                            <i class="fas fa-trash-alt"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @* Bảng tóm tắt đơn hàng *@
            <div class="col-lg-4 mt-4 mt-lg-0">
                <div class="card shadow-sm border-0 bg-light p-3">
                    <h4 class="fw-bold mb-3">Tạm tính</h4>
                    <hr />
                    <div class="d-flex justify-content-between mb-2">
                        <span>Số lượng món:</span>
                        <span class="fw-bold">@Model.Count</span>
                    </div>
                    <div class="d-flex justify-content-between mb-4">
                        <span>Tổng tiền:</span>
                        <h4 class="text-danger fw-bold">@Model.Sum(x => x.Total).ToString("N0") VNĐ</h4>
                    </div>
                    <a asp-controller="Cart" asp-action="Checkout" class="btn btn-success w-100 fw-bold py-2 mb-2">
                        TIẾN HÀNH ĐẶT HÀNG
                    </a>
                    <a href="@Url.Action("Index", "Menu")" class="btn btn-outline-secondary w-100 fw-bold">
                        TIẾP TỤC CHỌN MÓN
                    </a>
                </div>
            </div>
        </div>
    }
</div>